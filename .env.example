TNG_API_KEY=your_api_key_here

# Data storage configuration
# LOCAL: DATA_ROOT=./data
# GOOGLE DRIVE (Colab): DATA_ROOT=/content/drive/MyDrive/xai-dark-matter-data
# GOOGLE DRIVE (Local with rclone): DATA_ROOT=/mnt/xai-dark-matter-data
DATA_ROOT=./data
USE_GOOGLE_DRIVE=False

# Google Drive configuration (if USE_GOOGLE_DRIVE=True)
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

DATASET_NAME=TNG-DM-XAI-v1
TNG_SIMULATION=TNG100-1
TNG_SNAPSHOT=99